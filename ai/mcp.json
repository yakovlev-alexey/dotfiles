{
  "tracker": {
    "enabled": true,
    "transport": "local",
    "command": "$HOME/arcadia/ml/infra/model_context_protocol/tools/proxy_client/proxy_client",
    "args": [
      "-F",
      "$HOME/.mcp_store/oauth_token",
      "--endpoint",
      "mcp.yandex.net/ws?servers=tracker_mcp"
    ],
