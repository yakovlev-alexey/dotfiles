#!/usr/bin/env bash
set -euo pipefail

previous_head=$1
new_head=$2
branch_checkout=$3

if [[ "$branch_checkout" != "1" ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if git diff --name-only "$previous_head" "$new_head" |
  grep -Eq '^(home/|ai/instructions/|install\.conf\.yaml|profiles/)'; then
  ./scripts/check-links
fi
