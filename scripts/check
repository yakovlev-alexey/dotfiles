#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

while IFS= read -r script; do
  case "$script" in
    *.zsh|scripts/personal|scripts/build-agents-md|scripts/install-skills|scripts/install-plugins|scripts/install-mcp) zsh -n "$script" ;;
    *.sh|install|scripts/install-wsl-packages|scripts/check|scripts/check-links|scripts/install-git-hooks|githooks/*) bash -n "$script" ;;
  esac
done < <(find scripts shell home githooks -type f -print; printf '%s\n' install)

jq empty ai/skills/skills.json
jq empty ai/plugins/plugins.json
jq empty ai/mcp.json
jq empty opencode/opencode.template.json

if rg -n --hidden --glob '!dotbot/**' --glob '!ai/skills/**' --glob '!scripts/check' 'ELIZA_TOKEN=|YANDEX_MCP_PROXY_FILTER=' .; then
  echo "check: possible committed secret assignment" >&2
  exit 1
fi

echo "check: ok"
