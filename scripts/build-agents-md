#!/usr/bin/env zsh

emulate -LR zsh
set -euo pipefail

repo_root=${0:A:h:h}
instructions_dir="$repo_root/ai/instructions"
agents_output_dirs=(
  "$HOME/.agents"
  "$HOME/.codex"
  "$HOME/.config/opencode"
)
generated_marker='<!-- GENERATED by scripts/build-agents-md from ai/instructions/*.md. Do not edit by hand. -->'
cursor_agents_file="$HOME/.cursor/AGENTS.md"
cursor_rule_file="$HOME/.cursor/rules/dotfiles-agent-instructions.mdc"

tmp=$(mktemp "${TMPDIR:-/tmp}/agents-md.XXXXXX")
trap 'rm -f "$tmp"' EXIT

{
  print "$generated_marker"
  print
  first=1
  for file in "$instructions_dir"/*.md(N); do
    (( first )) || print
    cat "$file"
    first=0
  done
} > "$tmp"

for dir in "${agents_output_dirs[@]}"; do
  mkdir -p "$dir"
  cp "$tmp" "$dir/AGENTS.md"
  print "build-agents-md: synced $dir/AGENTS.md"
done

mkdir -p "${cursor_rule_file:h}"
{
  print -r -- '---'
  print -r -- 'alwaysApply: true'
  print -r -- '---'
  print
  cat "$tmp"
} > "$cursor_rule_file"
print "build-agents-md: synced $cursor_rule_file"

if [[ -f "$cursor_agents_file" ]]; then
  if grep -Fqx "$generated_marker" "$cursor_agents_file"; then
    rm "$cursor_agents_file"
    print "build-agents-md: removed stale $cursor_agents_file"
  else
    print "build-agents-md: leaving non-generated $cursor_agents_file in place" >&2
  fi
fi
