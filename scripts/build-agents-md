#!/usr/bin/env zsh

emulate -LR zsh
set -euo pipefail

repo_root=${0:A:h:h}
instructions_dir="$repo_root/ai/instructions"
output_dirs=(
  "$HOME/.agents"
  "$HOME/.codex"
  "$HOME/.cursor"
  "$HOME/.config/opencode"
)

tmp=$(mktemp "${TMPDIR:-/tmp}/agents-md.XXXXXX")
trap 'rm -f "$tmp"' EXIT

{
  print '<!-- GENERATED by scripts/build-agents-md from ai/instructions/*.md. Do not edit by hand. -->'
  print
  first=1
  for file in "$instructions_dir"/*.md(N); do
    (( first )) || print
    cat "$file"
    first=0
  done
} > "$tmp"

for dir in "${output_dirs[@]}"; do
  mkdir -p "$dir"
  cp "$tmp" "$dir/AGENTS.md"
  print "build-agents-md: synced $dir/AGENTS.md"
done
