#!/usr/bin/env zsh

emulate -LR zsh
set -euo pipefail

repo_root=${0:A:h:h}
mode=install

case "${1:-}" in
  "")
    ;;
  --check)
    mode=check
    ;;
  --dry-run)
    mode=dry-run
    ;;
  *)
    print -u2 "install-agent-hooks: unknown argument: $1"
    exit 2
    ;;
esac

node "$repo_root/scripts/lib/agent-hooks/render-agent-hooks.mjs" "$repo_root" "$mode"
