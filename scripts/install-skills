#!/usr/bin/env zsh

emulate -LR zsh
set -euo pipefail

repo_root=${0:A:h:h}
dotfiles_skills_root="$repo_root/ai/skills"
registry_path="$repo_root/ai/skills.json"
canonical_dir="$HOME/.agents/skills"
projection_dirs=("$HOME/.codex/skills" "$HOME/.cursor/skills")

die() {
  print -u2 "$1"
  exit 1
}

normalize_source() {
  local source=$1
  if [[ "$source" == '~' || "$source" == '~/'* ]]; then
    print -r -- "$HOME${source#\~}"
  elif [[ "$source" == ./* || "$source" == ../* ]]; then
    print -r -- "$repo_root/$source"
  elif [[ "$source" == /* || "$source" == *://* ]]; then
    print -r -- "$source"
  else
    print -r -- "https://github.com/$source"
  fi
}

copy_dir() {
  local src=$1 dst=$2
  [[ -d "$src" ]] || die "install-skills: missing directory: $src"
  rm -rf "$dst"
  mkdir -p "${dst:h}"
  cp -R "$src" "$dst"
}

install_owned_skills() {
  local root=$1
  local skill_dir name

  [[ -d "$root" ]] || return

  for skill_dir in "$root"/*(N/); do
    [[ -f "$skill_dir/SKILL.md" ]] || continue
    name=${skill_dir:t}
    copy_dir "$skill_dir" "$canonical_dir/$name"
    managed+=("$name")
  done
}

link_local_skill() {
  local src=$1 name=$2
  [[ -d "$src" ]] || die "install-skills: missing directory: $src"
  rm -rf "$canonical_dir/$name"
  ln -s "$src" "$canonical_dir/$name"
  managed+=("$name")
}

link_all_local_skills() {
  local source=$1
  local skill_dir count=0

  for skill_dir in "$source"/*(N/); do
    [[ -f "$skill_dir/SKILL.md" ]] || continue
    link_local_skill "$skill_dir" "${skill_dir:t}"
    (( count += 1 ))
  done

  (( count > 0 )) || die "install-skills: no skills found in local source: $source"
}

project_skill() {
  local src=$1 dir target current
  for dir in "${projection_dirs[@]}"; do
    mkdir -p "$dir"
    target="$dir/${src:t}"
    if [[ -L "$target" ]]; then
      current=$(readlink "$target")
      [[ "$current" == "$src" || "${current:A}" == "${src:A}" ]] && continue
      [[ "$current" == "$canonical_dir/"* ]] && rm -f "$target"
    elif [[ -e "$target" ]]; then
      if [[ -d "$target" && -d "$src" ]] && diff -qr "$target" "$src" >/dev/null 2>&1; then
        rm -rf "$target"
      else
        print "install-skills: keeping unmanaged entry: $target"
        continue
      fi
    fi
    ln -s "$src" "$target"
  done
}

mkdir -p "$canonical_dir" "${projection_dirs[@]}"
typeset -Ua managed
managed=()

if [[ -f "$registry_path" ]]; then
  while IFS= read -r entry; do
    source=$(normalize_source "$(jq -r '.key' <<<"$entry")")
    if [[ "$source" == /* && ! -e "$source" ]]; then
      if [[ "${INSTALL_SKILLS_STRICT:-0}" == 1 ]]; then
        die "install-skills: missing local skill source: $source"
      fi
      print -u2 "install-skills: skipping missing local skill source: $source"
      continue
    fi
    value_type=$(jq -r '.value | type' <<<"$entry")
    names=()

    if [[ "$value_type" == string ]]; then
      value=$(jq -r '.value' <<<"$entry")
      if [[ "$value" == "*" ]]; then
        if [[ -d "$source" && -f "$source/SKILL.md" ]]; then
          link_local_skill "$source" "${source:t}"
        elif [[ -d "$source" ]]; then
          link_all_local_skills "$source"
        else
          tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/dotfiles-skills.XXXXXX")
          trap 'rm -rf "$tmpdir"' EXIT
          (cd "$tmpdir" && pnpx skills add "$source" -a codex -y < /dev/null)
          for staged in "$tmpdir/.agents/skills"/*(N/); do
            names+=("${staged:t}")
            copy_dir "$staged" "$canonical_dir/${staged:t}"
          done
          managed+=("${names[@]}")
        fi
      else
        names=("$value")
      fi
    elif [[ "$value_type" == array ]]; then
      names=("${(@f)$(jq -r '.value[]' <<<"$entry")}")
    else
      die "install-skills: invalid registry entry: $entry"
    fi

    if [[ "$value_type" == array || ( "$value_type" == string && "$(jq -r '.value' <<<"$entry")" != "*" ) ]]; then
      if [[ -d "$source" ]]; then
        for name in "${names[@]}"; do
          [[ -d "$source/$name" ]] || die "install-skills: missing selected local skill: $source/$name"
          link_local_skill "$source/$name" "$name"
        done
      else
        tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/dotfiles-skills.XXXXXX")
        trap 'rm -rf "$tmpdir"' EXIT
        command=(pnpx skills add "$source" -a codex -y)
        for name in "${names[@]}"; do command+=(--skill "$name"); done
        (cd "$tmpdir" && "${command[@]}" < /dev/null)
        for name in "${names[@]}"; do
          [[ -d "$tmpdir/.agents/skills/$name" ]] || die "install-skills: staged skill not found: $name"
          copy_dir "$tmpdir/.agents/skills/$name" "$canonical_dir/$name"
        done
        managed+=("${names[@]}")
      fi
    fi
  done < <(jq -c 'to_entries[]' "$registry_path")
fi

install_owned_skills "$dotfiles_skills_root"

typeset -A keep
for name in "${managed[@]}"; do keep[$name]=1; done
for entry in "$canonical_dir"/*(N); do
  [[ -n "${keep[${entry:t}]-}" ]] || rm -rf "$entry"
done

for skill in "$canonical_dir"/*(N); do
  [[ -d "$skill" || -L "$skill" ]] || continue
  project_skill "$skill"
done

print "install-skills: synced ${#managed[@]} skills"
